<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Server Error - Demo</title>
    <style>
        body {
            height: 100vh;
            margin: 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background-color: #080b14;
            color: #f1f5f9;
            font-family: 'Inter', sans-serif;
            text-align: center;
        }
        .error-container {
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
        }
        h1 { font-size: 3rem; margin-bottom: 0.5rem; color: #ef4444; }
        p { color: #64748b; font-size: 1.1rem; }
        .btn-home {
            margin-top: 1.5rem;
            display: inline-block;
            padding: 10px 20px;
            background: #6366f1;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <h1><%= statusCode %></h1>
        <p><%= message %></p>
        <a href="/" class="btn-home">Return to Safety</a>
    </div>
</body>
</html>
