<% layout('layouts/main') %>
    <section class="about-hero text-center py-24 bg-dark-secondary relative overflow-hidden">
        <div class="container mx-auto px-6 relative z-10">
            <h1 class="text-5xl font-extrabold mb-6 gradient-text">
                About <%= company.name || 'AI' %>
            </h1>
            <p class="text-xl text-secondary max-w-3xl mx-auto leading-relaxed">
                <%= content %>
            </p>
        </div>
        <div class="absolute inset-0 opacity-10">
            <div class="bg-grid absolute inset-0"></div>
        </div>
    </section>

    <section class="mission py-24">
        <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
            <div>
                <h2 class="text-3xl font-bold mb-6 text-primary">Our Mission</h2>
                <div class="text-secondary space-y-4">
                    <p>We believe that your future shouldn't be determined by a 5-minute conversation under pressure. Our mission is to democratize visa interview preparation through advanced AI technology.</p>
                    <p>By simulating real-world embassy environments, we help thousands of students, workers, and travelers gain the confidence they need to succeed.</p>
                </div>
            </div>
            <div class="glass-card p-12 text-center">
                <div class="text-5xl font-bold text-accent mb-2">10,000+</div>
                <div class="text-secondary font-semibold uppercase tracking-widest text-sm">Interviews Practiced</div>
                <div class="mt-8 grid grid-cols-2 gap-4">
                    <div class="p-4 bg-surface rounded-lg">
                        <div class="text-2xl font-bold text-primary">92%</div>
                        <div class="text-xs text-muted">Success Rate</div>
                    </div>
                     <div class="p-4 bg-surface rounded-lg">
                        <div class="text-2xl font-bold text-primary">24/7</div>
                        <div class="text-xs text-muted">Availability</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-info py-24 bg-dark-secondary">
        <div class="container mx-auto px-6 text-center">
            <h2 class="text-3xl font-bold mb-12 text-primary">Get in Touch</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="glass-card p-8">
                    <div class="text-3xl mb-4">📧</div>
                    <h4 class="font-bold mb-2">Email Us</h4>
                    <p class="text-secondary"><%= company.contactEmail %></p>
                </div>
                <div class="glass-card p-8">
                    <div class="text-3xl mb-4">📞</div>
                    <h4 class="font-bold mb-2">Call Us</h4>
                    <p class="text-secondary"><%= company.contactPhone %></p>
                </div>
                <div class="glass-card p-8">
                    <div class="text-3xl mb-4">📍</div>
                    <h4 class="font-bold mb-2">Visit Us</h4>
                    <p class="text-secondary"><%= company.address %></p>
                </div>
            </div>
        </div>
    </section>
