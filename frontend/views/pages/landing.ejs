<!-- LANDING PAGE -->
<% layout('layouts/main') %>
    <% pageCSS='landing.css' ; pageJS='landing.js' ; %>

        <!-- Hero Section -->
        <section class="hero" id="hero">
            <div class="hero-bg-orbs">
                <div class="orb orb-1"></div>
                <div class="orb orb-2"></div>
                <div class="orb orb-3"></div>
            </div>
            <div class="container hero-content">
                <div class="hero-badge animate-fade-in">
                    <span class="badge-dot"></span>
                    AI-Powered Embassy Interview Simulator
                </div>
                <h1 class="hero-title animate-fade-in-up">
                    Ace Your Visa Interview<br />
                    with <span class="gradient-text">Embassy-Grade AI</span>
                </h1>
                <p class="hero-subtitle animate-fade-in-up delay-1">
                    Practice with a strict AI visa officer that asks real embassy questions,
                    detects nervousness, evaluates credibility, and gives you your approval probability.
                </p>
                <div class="hero-actions animate-fade-in-up delay-2">
                    <a href="/auth/login" class="btn btn-primary btn-lg" id="heroStartBtn">
                        Start Free Interview →
                    </a>
                    <a href="#features" class="btn btn-ghost btn-lg">See How It Works</a>
                </div>
                <div class="hero-stats animate-fade-in-up delay-3">
                    <div class="stat">
                        <span class="stat-number">98%</span>
                        <span class="stat-label">Accuracy</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat">
                        <span class="stat-number">5K+</span>
                        <span class="stat-label">Interviews Completed</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat">
                        <span class="stat-number">5</span>
                        <span class="stat-label">Countries</span>
                    </div>
                </div>
            </div>

            <!-- Mock Interview Preview Card -->
            <div class="container hero-preview animate-fade-in-up delay-2">
                <div class="preview-card glass-card">
                    <div class="preview-header">
                        <div class="officer-indicator">
                            <div class="officer-avatar">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg>
                            </div>
                            <div>
                                <p class="officer-name">US Embassy Officer</p>
                                <p class="officer-status"><span class="status-dot active"></span> Live Interview</p>
                            </div>
                        </div>
                        <div class="interview-timer">05:00</div>
                    </div>
                    <div class="preview-question">
                        <div class="question-bubble">
                            "What is the primary purpose of your visit to the United States, and how long do you intend
                            to
                            stay?"
                        </div>
                    </div>
                    <div class="preview-scores">
                        <div class="score-item">
                            <span class="score-label">Confidence</span>
                            <div class="score-bar">
                                <div class="score-fill" style="width:78%"></div>
                            </div>
                            <span class="score-val">78</span>
                        </div>
                        <div class="score-item">
                            <span class="score-label">Eye Contact</span>
                            <div class="score-bar">
                                <div class="score-fill" style="width:85%"></div>
                            </div>
                            <span class="score-val">85</span>
                        </div>
                        <div class="score-item">
                            <span class="score-label">Approval %</span>
                            <div class="score-bar green">
                                <div class="score-fill green" style="width:82%"></div>
                            </div>
                            <span class="score-val">82%</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="features" id="features">
            <div class="container">
                <div class="section-header">
                    <p class="section-label">Why AI</p>
                    <h2 class="section-title">Everything You Need to <span class="gradient-text">Pass</span></h2>
                    <p class="section-subtitle">Our AI replicates real embassy conditions and behavioral analysis</p>
                </div>
                <div class="features-grid">
                    <div class="feature-card glass-card animate-on-scroll">
                        <div class="feature-icon icon-blue">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <circle cx="12" cy="12" r="10" />
                                <path d="M12 16v-4M12 8h.01" />
                            </svg>
                        </div>
                        <h3>AI Officer</h3>
                        <p>Strict Gemini-powered officer that asks real embassy questions and detects inconsistencies.
                        </p>
                    </div>
                    <div class="feature-card glass-card animate-on-scroll">
                        <div class="feature-icon icon-purple">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </div>
                        <h3>Eye Contact Detection</h3>
                        <p>MediaPipe FaceMesh tracks gaze direction and scores your eye contact in real time.</p>
                    </div>
                    <div class="feature-card glass-card animate-on-scroll">
                        <div class="feature-icon icon-green">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="22,12 18,12 15,21 9,3 6,12 2,12" />
                            </svg>
                        </div>
                        <h3>Nervousness Analysis</h3>
                        <p>Detects blink rate, head motion, speech pauses, and hesitation patterns.</p>
                    </div>
                    <div class="feature-card glass-card animate-on-scroll">
                        <div class="feature-icon icon-orange">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            </svg>
                        </div>
                        <h3>Embassy Decision Engine</h3>
                        <p>Get approval probability, risk flags, suspicion indicators, and a final verdict.</p>
                    </div>
                    <div class="feature-card glass-card animate-on-scroll">
                        <div class="feature-icon icon-pink">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polygon
                                    points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" />
                            </svg>
                        </div>
                        <h3>5 Countries Supported</h3>
                        <p>USA, Canada, UK, Australia, Germany — each with country-specific question banks.</p>
                    </div>
                    <div class="feature-card glass-card animate-on-scroll">
                        <div class="feature-icon icon-cyan">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <line x1="18" y1="20" x2="18" y2="10" />
                                <line x1="12" y1="20" x2="12" y2="4" />
                                <line x1="6" y1="20" x2="6" y2="14" />
                            </svg>
                        </div>
                        <h3>Performance Analytics</h3>
                        <p>Track score improvements, approval trends, and credibility over multiple sessions.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Countries Section -->
        <section class="countries-section">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Practice for <span class="gradient-text">Any Destination</span></h2>
                </div>
                <div class="countries-grid">
                    <div class="country-card glass-card animate-on-scroll">
                        <span class="country-flag">🇺🇸</span>
                        <h3 class="country-name">USA</h3>
                        <p class="country-types">Student &bull; Tourist &bull; Work</p>
                        <a href="/auth/login" class="btn btn-ghost btn-sm">Practice →</a>
                    </div>
                    <div class="country-card glass-card animate-on-scroll">
                        <span class="country-flag">🇨🇦</span>
                        <h3 class="country-name">Canada</h3>
                        <p class="country-types">Student &bull; Tourist</p>
                        <a href="/auth/login" class="btn btn-ghost btn-sm">Practice →</a>
                    </div>
                    <div class="country-card glass-card animate-on-scroll">
                        <span class="country-flag">🇬🇧</span>
                        <h3 class="country-name">UK</h3>
                        <p class="country-types">Student &bull; Tourist</p>
                        <a href="/auth/login" class="btn btn-ghost btn-sm">Practice →</a>
                    </div>
                    <div class="country-card glass-card animate-on-scroll">
                        <span class="country-flag">🇦🇺</span>
                        <h3 class="country-name">Australia</h3>
                        <p class="country-types">Student</p>
                        <a href="/auth/login" class="btn btn-ghost btn-sm">Practice →</a>
                    </div>
                    <div class="country-card glass-card animate-on-scroll">
                        <span class="country-flag">🇩🇪</span>
                        <h3 class="country-name">Germany</h3>
                        <p class="country-types">Student &bull; Work</p>
                        <a href="/auth/login" class="btn btn-ghost btn-sm">Practice →</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section">
            <div class="container">
                <div class="cta-card glass-card">
                    <h2>Ready to Pass Your Visa Interview?</h2>
                    <p>Start your free trial interview today. No credit card required.</p>
                    <a href="/auth/login" class="btn btn-primary btn-lg">Start Free Now →</a>
                </div>
            </div>
        </section>

        <link rel="stylesheet" href="/css/landing.css" />
        <script src="/js/landing.js" defer></script>