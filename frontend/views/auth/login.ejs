<!-- AUTH: Login Page -->
<% layout('layouts/auth') %>
    <div class="auth-card glass-card">
        <!-- Brand -->
        <div class="auth-brand">
            <a href="/" class="brand-link-auth">
                <div class="brand-icon-auth">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                        <polyline points="9,22 9,12 15,12 15,22" />
                    </svg>
                </div>
                <span class="accent">AI</span>
            </a>
        </div>

        <h1 class="auth-title">Welcome Back</h1>
        <p class="auth-subtitle">Sign in with Google to continue your interview preparation</p>

        <!-- Error Toast -->
        <% if (error && error !== 'session_expired') { %>
            <div class="alert alert-error" role="alert">
                <% if (error==='session_expired' ) { %>
                    <% /* ⚠️ Your session expired. Please log in again. */ %>
                    <% } else { %>
                        ⚠️ <%= error %>
                            <% } %>
            </div>
            <% } %>

                <!-- Google Sign In -->
                <button class="btn-google" id="googleSignInBtn" type="button">
                    <svg width="20" height="20" viewBox="0 0 24 24">
                        <path fill="#4285F4"
                            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                        <path fill="#34A853"
                            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                        <path fill="#FBBC05"
                            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                        <path fill="#EA4335"
                            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                    </svg>
                    Continue with Google
                </button>

                <!-- Divider -->
                <div class="auth-divider">
                    <span>Secure Authentication</span>
                </div>

                <!-- Trust Signals -->
                <div class="auth-trust">
                    <div class="trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                        <span>256-bit Encrypted</span>
                    </div>
                    <div class="trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <polyline points="20,6 9,17 4,12" />
                        </svg>
                        <span>No Password Required</span>
                    </div>
                    <div class="trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12,6 12,12 16,14" />
                        </svg>
                        <span>1-Click Login</span>
                    </div>
                </div>

                <p class="auth-terms">
                    By signing in, you agree to our <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
                </p>
    </div>

    <script type="module">
        import { GoogleAuthProvider, signInWithPopup } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js';

        const btn = document.getElementById('googleSignInBtn');
        const redirect = '<%= redirect %>';

        btn.addEventListener('click', async () => {
            btn.disabled = true;
            btn.textContent = 'Signing in...';
            try {
                const provider = new GoogleAuthProvider();
                const result = await signInWithPopup(window.__firebaseAuth, provider);
                const idToken = await result.user.getIdToken();

                const res = await fetch('/auth/verify-token', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ idToken }),
                });
                const data = await res.json();
                if (data.success) {
                    window.location.href = data.data.redirect || redirect || '/dashboard';
                } else {
                    throw new Error(data.message);
                }
            } catch (err) {
                console.error(err);
                btn.disabled = false;
                btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24">...</svg> Continue with Google`;
                const alert = document.createElement('div');
                alert.className = 'alert alert-error';
                alert.textContent = '⚠️ ' + (err.message || 'Authentication failed. Please try again.');
                btn.parentNode.insertBefore(alert, btn);
                setTimeout(() => alert.remove(), 5000);
            }
        });
    </script>