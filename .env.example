# ============================================================
# EmbassyAI — Minimal .env
# ALL other credentials are configured via the /setup admin UI
# and stored encrypted in MongoDB. Only these values stay here.
# ============================================================

# ── MongoDB (REQUIRED) ──────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/embassy_ai

# ── Encryption key for secrets stored in MongoDB ────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CONFIG_ENCRYPTION_KEY=embassy_ai_default_encryption_key_32b

# ── Port (optional — can be set via /setup UI) ───────────────
PORT=5000
NODE_ENV=development

# ============================================================
# IMPORTANT: Visit http://localhost:5000/setup to configure:
#   - Firebase credentials
#   - Razorpay API keys  
#   - Cloudinary credentials
#   - OpenAI API key (sk-...)
#   - App session secret
# ============================================================
